.vscode/
.idea/
*.swp
*.swo

# Env
.env
.env.*
.env.local
.env.*.local
!.env.example
*.key
*.pem

# Supabase
supabase/.temp/

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
