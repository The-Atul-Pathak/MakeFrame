# ---------------------------------------------------------------------------
# MakeFrame environment configuration
#
# Copy this file to `.env` (which is git-ignored) and fill in real values.
# All client-exposed variables MUST be prefixed with VITE_ — Vite only inlines
# those into the browser bundle. NEVER put a service-role key or any server-only
# secret here: everything in a VITE_ variable is publicly visible in the bundle.
# ---------------------------------------------------------------------------

# Supabase project URL.
#   Local:  http://127.0.0.1:54321  (from `supabase status`)
#   Hosted: https://<project-ref>.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public API key. This is safe to expose in the browser; row-level
# security (RLS) is what actually protects your data. Do NOT use the service_role key.
#   Local:  from `supabase status`
#   Hosted: Project Settings → API → anon public
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Optional (Phase E — observability). Leave blank until configured.
# ---------------------------------------------------------------------------

# Sentry DSN for browser error reporting.
# VITE_SENTRY_DSN=

# App environment label surfaced in logs/error reports: development | staging | production
VITE_APP_ENV=development
